# ticket-server 배포용 환경변수 템플릿.
# 이 파일을 deploy/.env 로 복사한 뒤 실제 값을 채운다. deploy/.env 는 절대 커밋하지 않는다(.gitignore 처리됨).
#
#   cp deploy/.env.example deploy/.env

# === Datasource (배포 대상 PostgreSQL) ===
DB_URL=jdbc:postgresql://<infra-host>:5432/ticketserver
DB_USERNAME=ticketserver
DB_PASSWORD=<db-password>

# === Redis (비밀번호 재설정 토큰 저장) ===
REDIS_HOST=<infra-host>
REDIS_PORT=6380
REDIS_PASSWORD=<redis-password>

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=<infra-host>:9094

# === JWT (gateway·user-service 동일해야 함. 최소 32바이트) ===
JWT_SECRET=<generate-a-strong-random-secret>
JWT_ISSUER=ticket-server

# === 배포/표시용 ===
PUBLIC_HOST=<public-host-or-ip>   # 배포 후 안내 메시지에 표시할 외부 호스트
GATEWAY_PORT=18080
FE_PORT=13000
TAG=latest
