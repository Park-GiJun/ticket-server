# 줄바꿈 정규화: 저장소에는 항상 LF로 저장
* text=auto eol=lf

# 소스/설정 파일 LF 고정
*.kt         text eol=lf
*.kts        text eol=lf
*.java       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.properties text eol=lf
*.toml       text eol=lf
*.md         text eol=lf
*.xml        text eol=lf

# 쉘/배치 스크립트
/ticket-server-be/gradlew text eol=lf
*.sh         text eol=lf
*.bat        text eol=crlf

# 바이너리
*.jar        binary
